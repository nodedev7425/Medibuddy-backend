# MediBuddy example environment

# -----------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------

# Django secret key used for sessions, cookies and token generation.
# Generate a new key for production: https://djecrety.ir/
SECRET_KEY='django-insecure-example-secret-key'

# Enable Django debug mode.
# Never set DEBUG=True in production.
# Values: True | False
DEBUG=True

# Space-separated list of allowed hostnames.
# Examples:
#   localhost
#   localhost 127.0.0.1
#   api.example.com
ALLOWED_HOSTS=localhost

# Space-separated list of trusted origins for CSRF protection.
# Examples:
#   http://localhost:8000
#   https://api.example.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Directory used by Django collectstatic.
# Example:
#   /var/www/medibuddy/static
STATIC_ROOT=/opt/medibuddy/staticfiles

# -----------------------------------------------------------------------
# Box alert clean up task
# -----------------------------------------------------------------------

# Interval for the wipe process in minutes.
WIPE_INTERVAL=60

# Time until an alert expires in seconds.
# 172800 = 48 hours
ALERT_TIMEOUT=172800